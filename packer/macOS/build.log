task: [create] # Verify VM exists with correct name
echo "Verifying VM 'macos-base' exists..."
vm_found=$(osascript -e 'tell application "UTM" to get name of every virtual machine' 2>/dev/null | grep -c "macos-base" || echo "0")
if [ "$vm_found" -eq 0 ]; then
  echo ""
  echo "ERROR: VM 'macos-base' not found!"
  echo "Available VMs:"
  osascript -e 'tell application "UTM" to get name of every virtual machine'
  echo ""
  echo "The VM may have been created with a different name."
  echo "Please rename it manually or update VM_NAME in Taskfile.yml"
  exit 1
fi
echo "VM 'macos-base' verified!"

Verifying VM 'macos-base' exists...
VM 'macos-base' verified!
task: [setup] open -a UTM
task: [setup] sleep 2
task: [setup] # Start VM and wait for install confirmation dialog, then click OK
echo "=== Starting VM and confirming macOS installation ==="
osascript << 'EOF'
tell application "UTM"
    start virtual machine "macos-base"
end tell

tell application "System Events"
    tell process "UTM"
        set frontmost to true

        -- Wait up to 30 seconds for OK button to appear
        repeat 60 times
            try
                if exists button "OK" of sheet 1 of window 1 then
                    click button "OK" of sheet 1 of window 1
                    log "Clicked OK - macOS installation starting"
                    exit repeat
                end if
            end try
            delay 0.5
        end repeat
    end tell
end tell
EOF
echo "macOS installation started"

=== Starting VM and confirming macOS installation ===
