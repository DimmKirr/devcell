FROM ghcr.io/dimmkirr/devcell:{{VERSION}}

# Copy the user's flake (pinned to the matching devcell release).
# Edit flake.nix to customise packages, then run 'cell build'.
COPY --chown=1000:1000 flake.nix /opt/devcell/.config/home-manager/

# Activate the ultimate profile and install language runtimes.
RUN ARCH=$(uname -m) && \
    [ "$ARCH" = "aarch64" ] && ARCH_SUFFIX="-aarch64" || ARCH_SUFFIX="" && \
    /nix/var/nix/profiles/per-user/devcell/profile/bin/home-manager switch \
      --flake "/opt/devcell/.config/home-manager#devcell-ultimate${ARCH_SUFFIX}" \
      --impure && \
    ln -sfT "$(readlink -f /opt/devcell/.nix-profile)" \
            /nix/var/nix/profiles/per-user/devcell/profile && \
    /opt/devcell/.nix-profile/bin/asdf install nodejs && \
    /opt/devcell/.nix-profile/bin/asdf reshim

# Agent CLI tools (claude, codex, etc.)
COPY --chown=1000:1000 package.json /opt/npm-tools/
RUN cd /opt/npm-tools && npm install
ENV PATH="/opt/npm-tools/node_modules/.bin:${PATH}"

# Python tools
COPY --chown=1000:1000 pyproject.toml /opt/python-tools/
SHELL ["/bin/bash", "-c"]
RUN cd /opt/python-tools && uv sync
SHELL ["/bin/sh", "-c"]
ENV PATH="/opt/python-tools/.venv/bin:${PATH}"
