---
interface Props {
  title: string;
  description?: string;
  activeNav?: 'docs';
}

const {
  title,
  description = 'DevCell — Run AI coding agents in an isolated container.',
  activeNav,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;700&family=Inter:wght@700;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="e97edbc2-cf4c-4565-a9f2-21db19e1a57b"></script>
    <slot name="head" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <a href="/" class="logo"><!--
        --><svg class="logo-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64">
          <path class="bracket" d="M14 4 L4 4 L4 60 L14 60" fill="none" stroke="#111" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path class="bracket" d="M50 4 L60 4 L60 60 L50 60" fill="none" stroke="#111" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round"/>
          <line x1="30" y1="15" x2="30" y2="39" stroke="#E85D26" stroke-width="3.5" stroke-linecap="round"/>
          <line x1="19.6" y1="21" x2="40.4" y2="33" stroke="#E85D26" stroke-width="3.5" stroke-linecap="round"/>
          <line x1="19.6" y1="33" x2="40.4" y2="21" stroke="#E85D26" stroke-width="3.5" stroke-linecap="round"/>
          <circle cx="46" cy="44" r="4" fill="#AAAAAA"/>
        </svg><!--
        --><span class="logo-spacer"></span><!--
        --><span class="logo-dev-container"><span class="logo-dev">dev</span></span><!--
        --><span class="logo-accent">cell</span>
      </a>
      <button class="nav-toggle" aria-label="Menu" onclick="this.nextElementSibling.classList.toggle('open')">☰</button>
      <nav>
        <a href="/#why">Why it matters</a>
        <a href="/#inside">What's inside</a>
        <a href="/#quickstart">Quickstart</a>
        <a href="/docs/quickstart" class:list={[{ active: activeNav === 'docs' }]}>Docs</a>
        <a href="https://github.com/DimmKirr/devcell">GitHub</a>
      </nav>
    </header>

    <slot />

    <footer>
      <div class="footer-inner">
        <span>devcell — Apache 2.0 License</span>
        <span>
          <a href="https://github.com/DimmKirr/devcell">GitHub</a>
          &nbsp;·&nbsp;
          <a href="https://github.com/DimmKirr/devcell/issues">Issues</a>
          &nbsp;·&nbsp;
          <a href="https://github.com/DimmKirr/devcell/releases">Releases</a>
        </span>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --black: #111111;
    --white: #ffffff;
    --bg: #ffffff;
    --bg-muted: #F5F5F2;
    --accent: #C8FF00;
    --border: 2.5px solid #111111;
    --shadow: 4px 4px 0 #111111;
    --shadow-lg: 6px 6px 0 #111111;
    --font-mono: 'Fira Code', 'JetBrains Mono', 'Courier New', monospace;
    --font-sans: 'Inter', Arial, sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--black);
    line-height: 1.4;
    overflow-x: hidden;
  }

  /* HEADER */
  header {
    background: var(--white);
    border-bottom: var(--border);
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 1.3rem;
    font-weight: 900;
    letter-spacing: -1px;
    color: var(--black);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .logo-icon {
    flex-shrink: 0;
    width: 1.6em;
    height: 1.6em;
  }

  .logo-spacer {
    display: inline-block;
    width: 0;
    flex-shrink: 0;
    animation: logo-spacer-open 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.4s forwards;
  }

  .logo-dev-container {
    display: inline-block;
    max-width: 0;
    overflow: hidden;
    white-space: nowrap;
    margin-right: 0.25em;
    animation: logo-gap-open 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.4s forwards;
  }

  .logo-dev {
    opacity: 0;
    animation: logo-dev-fade 0.3s ease-out 0.7s forwards;
  }

  .logo-accent { background: var(--accent); padding: 0 3px; }

  @keyframes logo-spacer-open {
    0%   { width: 0; }
    100% { width: 0.25em; }
  }

  @keyframes logo-gap-open {
    0%   { max-width: 0; }
    100% { max-width: 4ch; }
  }

  @keyframes logo-dev-fade {
    0%   { opacity: 0; }
    100% { opacity: 1; }
  }

  nav a {
    color: var(--black);
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-left: 1.75rem;
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition: border-color 0.1s;
  }

  nav a:hover { border-bottom-color: var(--black); }
  nav a.active { border-bottom-color: var(--accent); }

  /* MOBILE NAV */
  .nav-toggle {
    display: none;
    background: none;
    border: none;
    font-size: 1.4rem;
    cursor: pointer;
    padding: 0.25rem;
    line-height: 1;
  }

  @media (max-width: 768px) {
    header { padding: 0.75rem 1.25rem; }
    .nav-toggle { display: block; }
    nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--white);
      border-bottom: var(--border);
      padding: 0.75rem 1.25rem;
      flex-direction: column;
      gap: 0;
    }
    nav.open { display: flex; }
    nav a {
      margin-left: 0;
      padding: 0.6rem 0;
      border-bottom: 1px solid #EEE;
      font-size: 0.82rem;
    }
    nav a:last-child { border-bottom: none; }
  }

  /* SHARED INLINE CODE */
  :not(pre) > code {
    background: #EFEFEF;
    border: 1.5px solid var(--black);
    padding: 0.1em 0.3em;
    font-family: var(--font-mono);
    font-size: 0.85em;
    white-space: nowrap;
  }

  /* SHARED BUTTON */
  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    border: var(--border);
    box-shadow: var(--shadow);
    transition: transform 0.1s, box-shadow 0.1s;
  }

  .btn:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 #111; }
  .btn:active { transform: translate(2px, 2px); box-shadow: 2px 2px 0 #111; }
  .btn-primary { background: var(--black); color: var(--white); }
  .btn-secondary { background: var(--white); color: var(--black); }

  /* FOOTER */
  footer {
    background: var(--black);
    color: #AAAAAA;
    border-top: var(--border);
    padding: 1.5rem 2rem;
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  footer a { color: var(--accent); text-decoration: none; }
  footer a:hover { text-decoration: underline; }
</style>
