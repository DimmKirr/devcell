---

<div class="qs-wrap" id="quickstart">
  <section>
    <p class="section-label">Getting started</p>
    <h2>Quickstart</h2>
    <div class="qs-grid">
      <ol class="steps">
        <li class="step">
          <span class="step-num">1</span>
          <div>
            <h4>Install</h4>
            <p><code>brew install DimmKirr/tap/devcell</code>. Requires <code>docker</code>.<br/>Platforms: macOS, Linux, Windows<sup style="color:#888; font-size:0.65rem;">(not verified yet)</sup></p>
          </div>
        </li>
        <li class="step">
          <span class="step-num">2</span>
          <div>
            <h4>Run from any project</h4>
            <p><code>cd my-project && cell claude</code>. First run picks a stack, scaffolds config, and builds. Works with <code>cell codex</code> and <code>cell opencode</code> too.</p>
          </div>
        </li>
      </ol>

      <div>
        <div class="code-block">
          <div class="code-bar">
            <span class="dot dot-r"></span>
            <span class="dot dot-y"></span>
            <span class="dot dot-g"></span>
          </div>
          <span class="line"><span class="cmt"># macOS & Linux</span></span>
          <span class="line"><span class="cmd">brew </span><span class="arg">install</span> DimmKirr/tap/devcell</span>
          <span class="gap"></span>
          <span class="line"><span class="cmt"># run from any project directory</span></span>
          <span class="line"><span class="cmd">cd </span>~/dev/my-project</span>
          <span class="line"><span class="cmd">cell </span><span class="arg">claude</span></span>
        </div>
      </div>
    </div>
  </section>
</div>
