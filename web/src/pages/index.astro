---
import Base from '../layouts/Base.astro';

const profiles = [
  { category: "AI Agents",            tools: ["Claude Code", "OpenAI Codex", "OpenCode"] },
  { category: "Languages & Runtimes", tools: ["Node.js", "Python", "Go", "Ruby", "Swift / Clang / LLVM"] },
  { category: "Infrastructure",       tools: ["Terraform", "OpenTofu", "Docker", "Compose", "Packer"] },
];
---

<style is:global>
    /* HERO */
    .hero-wrap { border-bottom: var(--border); }

    .hero {
      max-width: 1200px;
      margin: 0 auto;
      padding: 4rem 2rem 3rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; padding: 3rem 1.5rem; gap: 2.5rem; }
    }

    .hero-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #888;
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .hero-eyebrow::before {
      content: '';
      display: inline-block;
      width: 1.5rem;
      height: 2px;
      background: #888;
    }

    h1 {
      font-size: clamp(2.8rem, 6vw, 5rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -2px;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }

    h1 .hl {
      background: var(--accent);
      display: inline-block;
      padding: 0.05em 0.15em;
      line-height: 0.9;
    }

    .hero-desc {
      font-family: var(--font-mono);
      font-size: 0.95rem;
      line-height: 1.75;
      color: #444;
      margin-bottom: 2rem;
      max-width: 460px;
    }

    .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.75rem; }

    .hero-quote {
      border-left: 3px solid var(--black);
      padding: 0.75rem 1rem;
      background: var(--bg-muted);
      max-width: 460px;
    }

    .hero-quote p {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      line-height: 1.6;
      color: #333;
      margin-bottom: 0.35rem;
    }

    .hero-quote cite {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: #888;
      font-style: normal;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* TERMINAL */
    .terminal {
      background: #0D0D0D;
      font-family: var(--font-mono);
      font-size: 1rem;
      padding: 1.25rem 1.5rem;
      border: var(--border);
      box-shadow: var(--shadow-lg);
      line-height: 1.9;
    }

    .terminal-bar {
      display: flex;
      gap: 6px;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid #222;
    }

    .dot { width: 11px; height: 11px; border-radius: 50%; }
    .dot-r { background: #FF5F57; }
    .dot-y { background: #FFBD2E; }
    .dot-g { background: #28CA41; }

    .t-path   { color: #5F8AFF; }
    .t-branch { color: #C678DD; }
    .t-cmd    { color: #888; }
    .t-ok     { color: #98C379; }
    .t-dim    { color: #555; }
    .t-hr     { color: #333; line-height: 1.2; }
    .t-dot    { color: #AAAAAA; }
    .t-title  { color: #E5E5E5; font-weight: 700; }
    .t-ver    { color: #555; }
    .t-safe   { color: #98C379; }
    .t-safe .fa-solid { font-size: 0.85em; vertical-align: baseline; }
    .t-prompt { color: #fff; }
    .t-splash {
      display: flex;
      align-items: flex-start;
      margin: 0.1rem 0;
      font-family: var(--font-mono);
      font-size: inherit;
      letter-spacing: 0;
    }
    .t-splash-logo {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      grid-template-rows: repeat(7, 1fr);
      width: 8ch;
      height: 4.65em;
      margin-right: 1ch;
      align-self: center;
      flex-shrink: 0;
    }
    .t-splash-logo .b { background: #E85D26; }
    .t-splash-info {
      font-family: var(--font-mono);
      white-space: pre;
      line-height: 1.55;
      margin: 0;
      letter-spacing: 0;
    }

    /* SECTION */
    section { max-width: 1200px; margin: 0 auto; padding: 3rem 2rem; }

    .section-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #888;
      margin-bottom: 0.6rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .section-label::before {
      content: '';
      display: inline-block;
      width: 1rem;
      height: 2px;
      background: #888;
    }

    h2 {
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: -1px;
      margin-bottom: 2.5rem;
      border-bottom: var(--border);
      padding-bottom: 0.75rem;
    }

    /* CARDS */
    .does-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border: var(--border);
      box-shadow: var(--shadow-lg);
    }

    @media (max-width: 900px) { .does-grid { grid-template-columns: 1fr; } }

    .does-card {
      padding: 1.75rem;
      border-right: var(--border);
      border-bottom: var(--border);
      background: var(--white);
      transition: background 0.12s;
    }

    .does-card:nth-child(3n) { border-right: none; }
    .does-card:last-child { border-right: none; border-bottom: none; }
    .does-card:nth-child(3n+1):nth-last-child(-n+3) { border-bottom: none; }
    .does-card:nth-child(3n+2):nth-last-child(-n+2) { border-bottom: none; }
    .does-card:nth-child(3n):nth-last-child(-n+1)   { border-bottom: none; }
    .does-card:hover { background: var(--accent); }

    .does-card a, .step a {
      color: var(--black);
      font-weight: 900;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .does-card a:hover, .step a:hover { background: var(--accent); text-decoration: none; }

    .does-card h3 {
      font-size: 0.85rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 0.6rem;
    }

    .does-card p {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: #444;
      line-height: 1.65;
    }

    /* INSIDE */
    .features-wrap {
      background: var(--bg-muted);
      border-top: var(--border);
      border-bottom: var(--border);
    }

    .profiles-grid {
      border: var(--border);
      margin-bottom: 1rem;
    }

    .profile-row {
      display: grid;
      grid-template-columns: 13rem 1fr;
      border-bottom: 1px solid #CCCCCC;
      align-items: baseline;
    }

    .profile-row:last-child { border-bottom: none; }

    .profile-cat {
      font-size: 0.72rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 0.8rem 1.1rem;
      border-right: 1px solid #CCCCCC;
    }

    .profile-tools {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: #444;
      padding: 0.8rem 1.1rem;
    }

    @media (max-width: 600px) {
      .profile-row { grid-template-columns: 1fr; }
      .profile-cat { border-right: none; border-bottom: 1px solid #CCCCCC; }
    }

    .profiles-more {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: #888;
    }

    .profiles-more a {
      color: var(--black);
      font-weight: 900;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    /* EYEBROW STAR LINK */
    .eyebrow-stars {
      color: var(--black);
      text-decoration: none;
      font-family: var(--font-mono);
      font-size: 0.75rem;
    }
    .eyebrow-stars:hover { color: var(--black); text-decoration: underline; }

    /* QUICKSTART */
    .qs-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
      align-items: start;
    }

    @media (max-width: 768px) { .qs-grid { grid-template-columns: 1fr; } }

    .steps { list-style: none; }

    .step {
      display: flex;
      gap: 1.1rem;
      margin-bottom: 1.5rem;
      align-items: start;
    }

    .step-num {
      background: var(--accent);
      border: var(--border);
      box-shadow: 3px 3px 0 #111;
      width: 2.2rem;
      height: 2.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 900;
      font-size: 0.88rem;
      font-family: var(--font-mono);
      flex-shrink: 0;
    }

    .step h4 {
      font-size: 0.82rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 0.3rem;
    }

    .step p {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: #555;
      line-height: 1.6;
    }

    /* CODE BLOCK */
    .code-block {
      background: #0D0D0D;
      color: var(--accent);
      font-family: var(--font-mono);
      font-size: 0.8rem;
      padding: 1.4rem 1.5rem;
      border: var(--border);
      box-shadow: var(--shadow);
      line-height: 1.9;
      overflow-x: auto;
      margin-bottom: 1.25rem;
    }

    .code-bar {
      display: flex;
      gap: 6px;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid #222;
    }

    .code-block .line { display: block; }
    .code-block .gap { display: block; height: 0.35rem; }
    .code-block .cmt { color: #444; }
    .code-block .cmd { color: #E5E5E5; }
    .code-block .arg { color: var(--accent); }

    /* NOTE */
    .note {
      border: var(--border);
      background: var(--bg-muted);
      box-shadow: var(--shadow);
      padding: 1.1rem 1.25rem;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      line-height: 1.65;
      color: #444;
    }

    .note strong {
      font-family: var(--font-sans);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      display: block;
      margin-bottom: 0.35rem;
      color: var(--black);
    }
</style>

<Base title="devcell — Agentic coding, without the blast radius" description="An AI agent sandbox. Run Claude Code, Codex, or OpenCode with auto-approve — SSH keys, other repos, and your host filesystem stay completely out of reach.">
  <div class="hero-wrap">
    <div class="hero">
      <div>
        <p class="hero-eyebrow">AI Agent Sandbox · Apache 2.0 · <a href="https://github.com/DimmKirr/devcell" class="eyebrow-stars">★ Star on GitHub</a></p>
        <h1>Agentic Coding,<br/>Without the<br/><span class="hl">Blast Radius.</span></h1>
        <p class="hero-desc">
          You want your AI agent to just do things — no approval prompts, full dev cycle.
          But locally, auto-approve means the agent has your SSH keys, other repos,
          and every credential on the machine.<br/><br/>
          devcell is an AI agent sandbox: your project directory is mounted inside,
          everything else stays out.
        </p>
        <div class="hero-actions">
          <a href="https://github.com/DimmKirr/devcell" class="btn btn-primary">View on GitHub →</a>
          <a href="#quickstart" class="btn btn-secondary">Quickstart</a>
        </div>
        <blockquote class="hero-quote">
          <p>"Run this in a container, not your actual machine."</p>
          <cite>— Anthropic, Claude Code documentation</cite>
        </blockquote>
      </div>

      <div class="terminal">
        <div class="terminal-bar">
          <span class="dot dot-r"></span>
          <span class="dot dot-y"></span>
          <span class="dot dot-g"></span>
        </div>
        <div><span class="t-path">~/myproject</span> <span class="t-dim">$</span> <span class="t-cmd"> cell claude</span></div>
        <div class="t-dim">starting sandbox…</div>
        <div><span class="t-ok">✔</span><span class="t-dim"> mounted /home/alex/myproject</span></div>
        <div class="t-hr">───────────────────────────────────────</div>
        <div class="t-splash">
          <div class="t-splash-logo"><!--
  7x7 sextant-style asterisk
  row0--><span></span><span></span><span></span><span class="b"></span><span></span><span></span><span></span><!--
  row1--><span class="b"></span><span></span><span></span><span class="b"></span><span></span><span></span><span class="b"></span><!--
  row2--><span></span><span class="b"></span><span></span><span class="b"></span><span></span><span class="b"></span><span></span><!--
  row3--><span></span><span></span><span class="b"></span><span class="b"></span><span class="b"></span><span></span><span></span><!--
  row4--><span></span><span class="b"></span><span></span><span class="b"></span><span></span><span class="b"></span><span></span><!--
  row5--><span class="b"></span><span></span><span></span><span class="b"></span><span></span><span></span><span class="b"></span><!--
  row6--><span></span><span></span><span></span><span class="b"></span><span></span><span></span><span></span>
          </div>
          <pre class="t-splash-info">  <span class="t-title">Claude Code</span> <span class="t-ver">v2.1.49</span>
<span class="t-dot">·</span> <span class="t-dim">Sonnet 4.6 · Claude Max</span>
  <span class="t-path">/myproject</span>
  <span class="t-path">&nbsp;</span></pre>
        </div>
        <div class="t-hr">───────────────────────────────────────</div>
        <div><span class="t-prompt">❯</span><span class="t-cmd"> implement login form</span></div>
        <div class="t-hr">───────────────────────────────────────</div>
        <div><span class="t-safe">⏵⏵ auto-approve · <span style="color:#fff">[</span><span style="color:#E85D26">*</span><span style="color:#AAAAAA">.</span><span style="color:#fff">]</span> Cell Active</span></div>
      </div>
    </div>
  </div>

  <section id="why">
    <p class="section-label">Why it matters</p>
    <h2>Auto-approve, safely.</h2>
    <div class="does-grid">
      <div class="does-card">
        <h3>Blast radius bounded</h3>
        <p>SSH keys, other repos, host APIs — unreachable. The agent edits freely inside your project; your host system is completely untouched.</p>
      </div>
      <div class="does-card">
        <h3>One command, any project</h3>
        <p><code>cd my-project && cell claude</code> — working directory mounted automatically. No per-project config. Works for Claude Code, Codex, and OpenCode.</p>
      </div>
      <div class="does-card">
        <h3>Toolchain that won't break</h3>
        <p>Go, Node.js, Python, Ruby, Swift, Terraform and more, pre-installed and community-vetted. No download URLs to die. No version drift between machines.</p>
      </div>
      <div class="does-card">
        <h3>Secrets never touch your repo</h3>
        <p>Inject credentials at runtime via 1Password — API keys, tokens, and secrets stay in your vault, never written to the project directory.</p>
      </div>
      <div class="does-card">
        <h3>Local MCPs, zero data leakage</h3>
        <p>Playwright, Chromium, and other MCP servers run inside the sandbox. No host installs, no external servers — your data never leaves the machine.</p>
      </div>
      <div class="does-card">
        <h3>See what the agent sees</h3>
        <p>Connect via VNC or RDP to watch the agent interact with GUI apps, browsers, and desktop tools in real time.</p>
      </div>
    </div>
  </section>

  <div class="features-wrap" id="inside">
    <section>
      <p class="section-label">What's inside</p>
      <h2>Batteries included.</h2>
      <div class="profiles-grid">
        {profiles.map((group) => (
          <div class="profile-row">
            <span class="profile-cat">{group.category}</span>
            <span class="profile-tools">{group.tools.join(' · ')}</span>
          </div>
        ))}
      </div>
      <p class="profiles-more">Also includes Electronics & IoT, Desktop & GUI, Media & Docs, and local MCPs (Playwright, Chromium). <a href="https://github.com/DimmKirr/devcell/tree/main/nixhome">See all included tools →</a></p>
      <p class="profiles-more">Every tool comes from <a href="https://github.com/DimmKirr/devcell/tree/main/nixhome">nixhome</a> — fork it to add your own packages without losing upstream updates.</p>
    </section>
  </div>

  <section id="quickstart">
    <p class="section-label">Getting started</p>
    <h2>Quickstart</h2>
    <div class="qs-grid">
      <ol class="steps">
        <li class="step">
          <span class="step-num">1</span>
          <div>
            <h4>Install</h4>
            <p>macOS: <code>brew install DimmKirr/tap/devcell</code><br/>Linux: download from <a href="https://github.com/DimmKirr/devcell/releases">GitHub releases</a>. Requires <code>docker</code>.</p>
          </div>
        </li>
        <li class="step">
          <span class="step-num">2</span>
          <div>
            <h4>Run from any project</h4>
            <p><code>cd my-project && cell claude</code> — first run auto-builds the sandbox image (~5 min). Works with <code>cell codex</code> and <code>cell opencode</code> too.</p>
          </div>
        </li>
      </ol>

      <div>
        <div class="code-block">
          <div class="code-bar">
            <span class="dot dot-r"></span>
            <span class="dot dot-y"></span>
            <span class="dot dot-g"></span>
          </div>
          <span class="line"><span class="cmt"># macOS</span></span>
          <span class="line"><span class="cmd">brew </span><span class="arg">install</span> DimmKirr/tap/devcell</span>
          <span class="gap"></span>
          <span class="line"><span class="cmt"># run from any project directory</span></span>
          <span class="line"><span class="cmd">cd </span>~/dev/my-project</span>
          <span class="line"><span class="cmd">cell </span><span class="arg">claude</span></span>
        </div>
      </div>
    </div>
  </section>
</Base>
