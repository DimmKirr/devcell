---
import Base from '../layouts/Base.astro';

const stacks = [
  { category: "AI Agents",             tools: ["Claude Code", "OpenAI Codex", "OpenCode"] },
  { category: "Languages & Runtimes",  tools: ["Go", "Node.js", "Python", "Ruby", "Swift / LLVM"] },
  { category: "Infrastructure & IaC",  tools: ["Terraform", "OpenTofu", "Docker", "Compose", "Packer", "Helm", "Nix"] },
  { category: "Finance & Data",        tools: ["Yahoo Finance", "EdgarTools SEC", "FRED API"] },
  { category: "Productivity & Travel", tools: ["Linear", "Notion", "Inoreader RSS", "Google Maps", "TripIt"] },
  { category: "Electronics & Design",  tools: ["KiCad", "Inkscape (vector graphics)", "ngspice", "ESPHome", "wokwi-cli"] },
  { category: "Desktop & Browser",     tools: ["VNC", "RDP", "Chromium (stealth)", "Playwright", "PulseAudio"] },
];

const logos = [
  { src: "/logos/claude-icon.svg", alt: "Claude", title: "Claude Code" },
  { src: "/logos/openai-icon.svg", alt: "OpenAI", title: "OpenAI Codex" },
  { src: "/logos/ollama.svg", alt: "Ollama", title: "Ollama (local models)" },
  { src: "/logos/go.svg", alt: "Go", title: "Go" },
  { src: "/logos/nodejs-icon.svg", alt: "Node.js", title: "Node.js 22" },
  { src: "/logos/python.svg", alt: "Python", title: "Python 3.13" },
  { src: "/logos/ruby.svg", alt: "Ruby", title: "Ruby" },
  { src: "/logos/swift.svg", alt: "Swift", title: "Swift / LLVM" },
  { src: "/logos/terraform-icon.svg", alt: "Terraform", title: "Terraform" },
  { src: "/logos/opentofu.svg", alt: "OpenTofu", title: "OpenTofu" },
  { src: "/logos/docker-icon.svg", alt: "Docker", title: "Docker" },
  { src: "/logos/nix.svg", alt: "Nix", title: "Nix" },
  { src: "/logos/packer.svg", alt: "Packer", title: "Packer" },
  { src: "/logos/git-icon.svg", alt: "Git", title: "Git" },
  { src: "/logos/tmux.svg", alt: "tmux", title: "tmux (terminal multiplexer)" },
  { src: "/logos/chrome.svg", alt: "Chromium", title: "Stealth Chromium" },
  { src: "/logos/playwright.svg", alt: "Playwright", title: "Playwright" },
  { src: "/logos/google-maps.svg", alt: "Google Maps", title: "Google Maps MCP" },
  { src: "/logos/linear-icon.svg", alt: "Linear", title: "Linear MCP" },
  { src: "/logos/notion-icon.svg", alt: "Notion", title: "Notion MCP" },
  { src: "/logos/inkscape.svg", alt: "Inkscape", title: "Inkscape (vector graphics)" },
  { src: "/logos/kicad.svg", alt: "KiCad", title: "KiCad EDA" },
  { src: "/logos/sqlite.svg", alt: "SQLite", title: "SQLite" },
  { src: "/logos/postgresql.svg", alt: "PostgreSQL", title: "PostgreSQL" },
  { src: "/logos/1password.svg", alt: "1Password", title: "1Password (secret injection)" },
];

const stackColumns = ["base", "go", "node", "python", "fullstack", "electronics", "ultimate"];
const stackFeatures = [
  { name: "Dev essentials",  note: "zsh, git, tmux, ripgrep, jq, sqlite, mise, nix", in: ["base","go","node","python","fullstack","electronics","ultimate"] },
  { name: "Go environment",      note: "Go toolchain",                                 in: ["go","fullstack","ultimate"] },
  { name: "Node.js environment", note: "Node.js 22, npm",                             in: ["node","fullstack","ultimate"] },
  { name: "Python environment",  note: "Python 3.13, uv",                             in: ["python","fullstack","ultimate"] },
  { name: "Infra tools",     note: "Terraform, OpenTofu, Packer, Helm",               in: ["go","fullstack","ultimate"] },
  { name: "Stealth browser", note: "Anti-fingerprint Chromium + Playwright",           in: ["node","python","fullstack","ultimate"], partial: ["node","python","fullstack"] },
  { name: "Electronics & DIY", note: "KiCad, ngspice, ESPHome, wokwi-cli",            in: ["electronics","ultimate"] },
  { name: "GUI desktop",     note: "VNC + RDP + Fluxbox + PulseAudio",                in: ["electronics","ultimate"] },
  { name: "12+ MCP servers",  note: "Finance, maps, productivity, vector graphics (Inkscape) — growing",   in: ["ultimate"] },
];

const dcRows = [
  { feature: "Designed for", devcell: "AI coding agents (Claude Code, Codex, OpenCode)", devcontainers: "VS Code and GitHub Codespaces" },
  { feature: "Setup",        devcell: "cell claude — zero config, works from any project",    devcontainers: "Write a Dockerfile + devcontainer.json per project" },
  { feature: "Toolchain",    devcell: "7 pre-built Nix-pinned stacks. Nothing to maintain",   devcontainers: "You build and maintain your own image" },
  { feature: "MCP servers",  devcell: "12+ servers auto-merged into agent config at startup",  devcontainers: "Not included. Install and configure yourself" },
  { feature: "Secrets",      devcell: "1Password injection at runtime, never written to disk", devcontainers: "Env files or docker-compose secrets" },
  { feature: "Browser",      devcell: "Stealth Chromium + Playwright, passes bot detection",   devcontainers: "Not included" },
  { feature: "GUI desktop",  devcell: "VNC + RDP built in, watch the agent work visually",     devcontainers: "Not included" },
  { feature: "Permissions",  devcell: "Host UID pass-through, no file ownership issues",       devcontainers: "remoteUser config in devcontainer.json" },
  { feature: "Agent auth",   devcell: "Claude Max/Pro subscription works directly",            devcontainers: "You handle auth yourself" },
];

const faqItems = [
  { q: "Do I need an API key or Claude subscription?",
    a: "Bring your own license or model. Claude Max, Pro, and API keys all work — devcell starts the same client you already use, just inside a container. Same goes for Codex and OpenCode." },
  { q: "Can the agent install packages inside the container?",
    a: "Yes. The agent can run apt, npm install, pip install, nix — whatever the project needs. Network access is unrestricted. Port forwarding for dev servers is coming soon." },
  { q: "What about file permissions?",
    a: "Permissions are pass-through. The container user matches your host UID, so files the agent creates are owned by you. No chown headaches." },
  { q: "Does my existing Claude Code config carry over?",
    a: "Your project-level config (CLAUDE.md, .claude/) is mounted with your project. Host ~/.claude/skills is mounted read-write, the rest of ~/.claude is read-only. Your host-machine config stays safe. (Subject to change.)" },
  { q: "Why not just run Docker myself?",
    a: "You can. devcell saves you from maintaining a Dockerfile per project, wiring up MCP server configs, forwarding git identity, injecting secrets, and setting up entrypoint orchestration. One command instead of 20 minutes of Docker plumbing." },
  { q: "How big are the images?",
    a: "Base is ~1.3 GB, ultimate is ~20 GB. First run builds locally (~5 min). Pre-built images are published to ghcr.io for faster pulls." },
];

const vsRows = [
  { feature: "Built for",   devcell: "AI coding agents, with finance, maps, and design MCP servers included",  openclaw: "Multi-channel messaging hub (WhatsApp, Telegram, Slack)" },
  { feature: "Setup",       devcell: "cd my-project && cell claude",                                            openclaw: "Gateway daemon + WebSocket config + channel integrations" },
  { feature: "Toolchain",   devcell: "7 Nix-pinned stacks with per-project config. Go, Node.js, Python, Terraform, Chromium, KiCad",    openclaw: "Shell + file access, no pre-built dev environment. Tool config is system-wide only" },
  { feature: "MCP servers", devcell: "12 curated, auto-merged at startup. Backing tools (OpenTofu, KiCad, Inkscape) ship in the image",                               openclaw: 'Open marketplace, no mandatory code review. 1,184 malicious skills found <sup><a href="https://thehackernews.com/2026/02/researchers-find-341-malicious-clawhub.html" target="_blank">[1]</a></sup>' },
  { feature: "Security",    devcell: "Mandatory container isolation, no exposed ports, no plugin marketplace",   openclaw: 'Network-exposed by default. 21,000+ instances found on public internet <sup><a href="https://censys.com/blog/openclaw-in-the-wild-mapping-the-public-exposure-of-a-viral-ai-assistant/" target="_blank">[2]</a></sup>' },
  { feature: "Claude sub",  devcell: "Claude Max and Pro work out of the box. Runs Claude Code directly",       openclaw: "Subscription auth blocked by Anthropic since Jan 2026. Requires API key (pay-per-use) or a proxy like OpenRouter" },
  { feature: "Privacy",     devcell: "Agent runs locally, talks to the API from your machine",                  openclaw: "Messages route through centralized server infrastructure" },
  { feature: "Isolation",   devcell: "Always on. SSH keys, credentials, host FS unreachable",                   openclaw: 'Optional, off by default. Multiple critical CVEs in 2026 <sup><a href="https://www.sonicwall.com/blog/openclaw-auth-token-theft-leading-to-rce-cve-2026-25253" target="_blank">[3]</a></sup> <sup><a href="https://www.oasis.security/blog/openclaw-vulnerability" target="_blank">[4]</a></sup>' },
];
---

<style is:global>
    /* HERO */
    .hero-wrap { border-bottom: var(--border); }

    .hero {
      max-width: 1200px;
      margin: 0 auto;
      padding: 4rem 2rem 3rem;
      display: grid;
      grid-template-columns: 7fr 5fr;
      gap: 3rem;
      align-items: start;
    }

    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; padding: 3rem 1.5rem; gap: 2.5rem; }
    }

    .hero-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #888;
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .hero-eyebrow::before {
      content: '';
      display: inline-block;
      width: 1.5rem;
      height: 2px;
      background: #888;
    }

    h1 {
      font-size: clamp(2.8rem, 6vw, 5rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -2px;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }

    h1 .hl {
      background: var(--accent);
      display: inline-block;
      padding: 0.05em 0.15em;
      line-height: 0.9;
    }

    .hero-desc {
      font-family: var(--font-mono);
      font-size: 0.95rem;
      line-height: 1.75;
      color: #444;
      margin-bottom: 2rem;
      max-width: 460px;
    }

    .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.75rem; }

    .hero-quote {
      border-left: 3px solid var(--black);
      padding: 0.75rem 1rem;
      background: var(--bg-muted);
      max-width: 460px;
    }

    .hero-quote p {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      line-height: 1.6;
      color: #333;
      margin-bottom: 0.35rem;
    }

    .hero-quote cite {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: #888;
      font-style: normal;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* TERMINAL */
    .terminal {
      background: #0D0D0D;
      font-family: var(--font-mono);
      font-size: 1rem;
      padding: 1.25rem 1.5rem;
      border: var(--border);
      box-shadow: var(--shadow-lg);
      line-height: 1.9;
      position: sticky;
      top: 5rem;
    }

    .terminal-bar {
      display: flex;
      gap: 6px;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid #222;
    }

    .dot { width: 11px; height: 11px; border-radius: 50%; }
    .dot-r { background: #FF5F57; }
    .dot-y { background: #FFBD2E; }
    .dot-g { background: #28CA41; }

    .t-path   { color: #5F8AFF; }
    .t-branch { color: #C678DD; }
    .t-cmd    { color: #888; }
    .t-ok     { color: #98C379; }
    .t-dim    { color: #555; }
    .t-hr     { color: #333; line-height: 1.2; }
    .t-dot    { color: #AAAAAA; }
    .t-title  { color: #E5E5E5; font-weight: 700; }
    .t-ver    { color: #555; }
    .t-safe   { color: #98C379; }
    .t-safe .fa-solid { font-size: 0.85em; vertical-align: baseline; }
    .t-prompt { color: #fff; }
    .t-splash {
      display: flex;
      align-items: flex-start;
      margin: 0.1rem 0;
      font-family: var(--font-mono);
      font-size: inherit;
      letter-spacing: 0;
    }
    .t-splash-logo {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      grid-template-rows: repeat(7, 1fr);
      width: 8ch;
      height: 4.65em;
      margin-right: 1ch;
      align-self: center;
      flex-shrink: 0;
    }
    .t-splash-logo .b { background: #E85D26; }
    .t-splash-info {
      font-family: var(--font-mono);
      white-space: pre;
      line-height: 1.55;
      margin: 0;
      letter-spacing: 0;
    }

    /* SECTION */
    section { max-width: 1200px; margin: 0 auto; padding: 3rem 2rem; }

    .section-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #888;
      margin-bottom: 0.6rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .section-label::before {
      content: '';
      display: inline-block;
      width: 1rem;
      height: 2px;
      background: #888;
    }

    h2 {
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: -1px;
      margin-bottom: 2.5rem;
      border-bottom: var(--border);
      padding-bottom: 0.75rem;
    }

    /* CARDS */
    .does-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border: var(--border);
      box-shadow: var(--shadow-lg);
    }

    @media (max-width: 900px) { .does-grid { grid-template-columns: 1fr; } }

    .does-card {
      padding: 1.75rem;
      border-right: var(--border);
      border-bottom: var(--border);
      background: var(--white);
      transition: background 0.12s;
    }

    .does-card:nth-child(3n) { border-right: none; }
    .does-card:last-child { border-right: none; border-bottom: none; }
    .does-card:nth-child(3n+1):nth-last-child(-n+3) { border-bottom: none; }
    .does-card:nth-child(3n+2):nth-last-child(-n+2) { border-bottom: none; }
    .does-card:nth-child(3n):nth-last-child(-n+1)   { border-bottom: none; }
    .does-card:hover { background: var(--accent); }

    .does-card a, .step a {
      color: var(--black);
      font-weight: 900;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .does-card a:hover, .step a:hover { background: var(--accent); text-decoration: none; }

    .does-card h3 {
      font-size: 0.85rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 0.6rem;
    }

    .does-card p {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: #444;
      line-height: 1.65;
    }

    /* INSIDE */
    .features-wrap {
      background: var(--bg-muted);
      border-top: var(--border);
      border-bottom: var(--border);
    }

    .stacks-grid {
      border: var(--border);
      margin-bottom: 1rem;
    }

    .stack-row {
      display: grid;
      grid-template-columns: 13rem 1fr;
      border-bottom: 1px solid #CCCCCC;
      align-items: baseline;
    }

    .stack-row:last-child { border-bottom: none; }

    .stack-cat {
      font-size: 0.72rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 0.8rem 1.1rem;
      border-right: 1px solid #CCCCCC;
    }

    .stack-tools {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: #444;
      padding: 0.8rem 1.1rem;
    }

    @media (max-width: 600px) {
      .stack-row { grid-template-columns: 1fr; }
      .stack-cat { border-right: none; border-bottom: 1px solid #CCCCCC; }
    }

    .stacks-more {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: #888;
    }

    .stacks-more a {
      color: var(--black);
      font-weight: 900;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    /* LOGO GRID */
    .logo-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 1.25rem;
      align-items: center;
      justify-content: center;
      padding: 1.5rem 0;
      margin-bottom: 1rem;
    }

    .logo-grid img {
      height: 28px;
      width: auto;
      filter: grayscale(100%) opacity(0.5);
      transition: filter 0.2s;
    }

    .logo-grid img:hover {
      filter: grayscale(0%) opacity(1);
    }

    .logo-item {
      position: relative;
      display: flex;
      align-items: center;
    }

    .logo-item::after {
      content: attr(data-title);
      position: absolute;
      bottom: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      background: var(--black);
      color: var(--white);
      font-family: var(--font-mono);
      font-size: 0.65rem;
      padding: 0.25rem 0.5rem;
      white-space: nowrap;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.15s;
    }

    .logo-item:hover::after {
      opacity: 1;
    }

    /* EYEBROW STAR LINK */
    .eyebrow-stars {
      color: var(--black);
      text-decoration: none;
      font-family: var(--font-mono);
      font-size: 0.75rem;
    }
    .eyebrow-stars:hover { color: var(--black); text-decoration: underline; }

    /* QUICKSTART */
    .qs-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
      align-items: start;
    }

    @media (max-width: 768px) { .qs-grid { grid-template-columns: 1fr; } }

    .steps { list-style: none; }

    .step {
      display: flex;
      gap: 1.1rem;
      margin-bottom: 1.5rem;
      align-items: start;
    }

    .step-num {
      background: var(--accent);
      border: var(--border);
      box-shadow: 3px 3px 0 #111;
      width: 2.2rem;
      height: 2.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 900;
      font-size: 0.88rem;
      font-family: var(--font-mono);
      flex-shrink: 0;
    }

    .step h4 {
      font-size: 0.82rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 0.3rem;
    }

    .step p {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: #555;
      line-height: 1.6;
    }

    /* CODE BLOCK */
    .code-block {
      background: #0D0D0D;
      color: var(--accent);
      font-family: var(--font-mono);
      font-size: 0.8rem;
      padding: 1.4rem 1.5rem;
      border: var(--border);
      box-shadow: var(--shadow);
      line-height: 1.9;
      overflow-x: auto;
      margin-bottom: 1.25rem;
    }

    .code-bar {
      display: flex;
      gap: 6px;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid #222;
    }

    .code-block .line { display: block; }
    .code-block .gap { display: block; height: 0.35rem; }
    .code-block .cmt { color: #444; }
    .code-block .cmd { color: #E5E5E5; }
    .code-block .arg { color: var(--accent); }

    /* NOTE */
    .note {
      border: var(--border);
      background: var(--bg-muted);
      box-shadow: var(--shadow);
      padding: 1.1rem 1.25rem;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      line-height: 1.65;
      color: #444;
    }

    .note strong {
      font-family: var(--font-sans);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      display: block;
      margin-bottom: 0.35rem;
      color: var(--black);
    }

    /* PLAN GRID */
    .plan-grid {
      border: var(--border);
      box-shadow: var(--shadow);
      overflow-x: auto;
      margin-bottom: 1.5rem;
    }

    .plan-grid table {
      width: 100%;
      border-collapse: collapse;
      min-width: 680px;
    }

    .plan-grid th {
      font-size: 0.7rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 0.7rem 0.5rem;
      text-align: center;
      border-bottom: var(--border);
      border-right: 1px solid #CCC;
      background: var(--white);
    }

    .plan-grid th:first-child {
      text-align: left;
      padding-left: 1rem;
      width: 11rem;
    }

    .plan-grid th:last-child { border-right: none; }

    .plan-grid th.col-default {
      background: var(--accent);
    }

    .plan-grid td {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      padding: 0.5rem 0.5rem;
      text-align: center;
      border-bottom: 1px solid #CCC;
      border-right: 1px solid #CCC;
      color: #DDD;
    }

    .plan-grid td:first-child {
      text-align: left;
      padding-left: 1rem;
      font-family: var(--font-sans);
      font-weight: 700;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--black);
    }

    .plan-grid td:last-child { border-right: none; }
    .plan-grid tr:last-child td { border-bottom: none; }

    .plan-grid td.col-default {
      background: color-mix(in srgb, var(--accent) 12%, white);
    }

    .plan-grid .has {
      color: var(--black);
      font-weight: 700;
    }

    .plan-grid sup {
      color: #888;
      font-size: 0.6rem;
      font-weight: 400;
    }

    /* IMAGE STACKS TABLE */
    .tag-default {
      background: var(--accent);
      font-size: 0.6rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 0.1em 0.35em;
      margin-left: 0.5rem;
      border: 1px solid var(--black);
    }

    /* QUICKSTART WRAP */
    .qs-wrap {
      background: var(--bg-muted);
      border-top: var(--border);
      border-bottom: var(--border);
    }

    /* VS COMPARISON */
    .compare-wrap {
      background: var(--bg-muted);
      border-top: var(--border);
      border-bottom: var(--border);
    }

    .vs-table {
      border: var(--border);
      box-shadow: var(--shadow);
      overflow-x: auto;
    }

    .vs-header {
      display: grid;
      grid-template-columns: 9rem 1fr 1fr;
      border-bottom: var(--border);
      background: var(--white);
    }

    .vs-header span {
