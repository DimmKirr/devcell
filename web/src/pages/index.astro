---
import Base from '../layouts/Base.astro';

const features = [
  {
    category: "AI Agents",
    items: [
      { name: "Claude Code", desc: "Isolated container with full project file access" },
      { name: "OpenAI Codex", desc: "Runs with correct environment and terminal support" },
      { name: "OpenCode", desc: "Open-source coding agent with MCP server integration" },
    ],
  },
  {
    category: "Languages & Runtimes",
    items: [
      { name: "asdf", desc: "Node.js, Python 3.13, Go, Ruby — versions pinned via .tool-versions" },
      { name: "Swift / Clang / LLVM", desc: "Open-source Apple toolchain available on Linux" },
      { name: "Nix home-manager", desc: "Declarative environment profiles, byte-identical across machines" },
    ],
  },
  {
    category: "Infrastructure",
    items: [
      { name: "Terraform / OpenTofu", desc: "IaC toolchain with OpenTofu MCP server" },
      { name: "Docker & Compose", desc: "Docker CLI with Compose plugin" },
      { name: "Packer", desc: "Machine image building" },
    ],
  },
  {
    category: "Electronics & IoT",
    items: [
      { name: "ESPHome", desc: "ESP microcontroller firmware configuration" },
      { name: "Wokwi CLI", desc: "Circuit simulation without hardware" },
      { name: "ngspice", desc: "SPICE circuit simulator" },
    ],
  },
  {
    category: "Desktop & GUI",
    items: [
      { name: "VNC", desc: "Full desktop environment accessible via VNC" },
      { name: "X11 forwarding", desc: "GUI apps rendered on your host screen" },
      { name: "Playwright MCP", desc: "Browser automation with secrets injection" },
    ],
  },
  {
    category: "Media & Docs",
    items: [
      { name: "ffmpeg / ImageMagick", desc: "Media processing" },
      { name: "Slidev", desc: "Markdown-based presentations" },
      { name: "yt-dlp", desc: "Video downloader" },
    ],
  },
];
---

<style is:global>
    /* HERO */
    .hero-wrap { border-bottom: var(--border); }

    .hero {
      max-width: 1200px;
      margin: 0 auto;
      padding: 4rem 2rem 3rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; padding: 3rem 1.5rem; gap: 2.5rem; }
    }

    .hero-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #888;
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .hero-eyebrow::before {
      content: '';
      display: inline-block;
      width: 1.5rem;
      height: 2px;
      background: #888;
    }

    h1 {
      font-size: clamp(2.8rem, 6vw, 5rem);
      font-weight: 900;
      line-height: 1.05;
      letter-spacing: -2px;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }

    h1 .hl { background: var(--accent); padding: 0 0.1em; }

    .hero-desc {
      font-family: var(--font-mono);
      font-size: 0.95rem;
      line-height: 1.75;
      color: #444;
      margin-bottom: 2rem;
      max-width: 460px;
    }

    .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

    /* TERMINAL */
    .terminal {
      background: #0D0D0D;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      padding: 1.25rem 1.5rem;
      border: var(--border);
      box-shadow: var(--shadow-lg);
      line-height: 1.9;
    }

    .terminal-bar {
      display: flex;
      gap: 6px;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid #222;
    }

    .dot { width: 11px; height: 11px; border-radius: 50%; }
    .dot-r { background: #FF5F57; }
    .dot-y { background: #FFBD2E; }
    .dot-g { background: #28CA41; }

    .t-path { color: #5F8AFF; }
    .t-branch { color: #C678DD; }
    .t-cmd { color: #E5E5E5; }
    .t-ok { color: #98C379; }
    .t-dim { color: #555; }
    .t-cursor { color: var(--accent); animation: blink 1s step-end infinite; }
    @keyframes blink { 50% { opacity: 0; } }

    /* SECTION */
    section { max-width: 1200px; margin: 0 auto; padding: 3rem 2rem; }

    .section-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #888;
      margin-bottom: 0.6rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .section-label::before {
      content: '';
      display: inline-block;
      width: 1rem;
      height: 2px;
      background: #888;
    }

    h2 {
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: -1px;
      margin-bottom: 2.5rem;
      border-bottom: var(--border);
      padding-bottom: 0.75rem;
    }

    /* WHAT IT DOES */
    .does-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border: var(--border);
      box-shadow: var(--shadow-lg);
    }

    @media (max-width: 900px) { .does-grid { grid-template-columns: 1fr; } }

    .does-card {
      padding: 1.75rem;
      border-right: var(--border);
      border-bottom: var(--border);
      background: var(--white);
      transition: background 0.12s;
    }

    .does-card:nth-child(3n) { border-right: none; }
    .does-card:nth-last-child(-n+3) { border-bottom: none; }
    .does-card:hover { background: var(--accent); }

    .does-card h3 {
      font-size: 0.85rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 0.6rem;
    }

    .does-card p {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: #444;
      line-height: 1.65;
    }

    /* FEATURES */
    .features-wrap {
      background: var(--bg-muted);
      border-top: var(--border);
      border-bottom: var(--border);
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }

    @media (max-width: 768px) { .features-grid { grid-template-columns: 1fr; } }

    .feat-group {
      background: var(--white);
      border: var(--border);
      box-shadow: var(--shadow);
      overflow: hidden;
      transition: transform 0.1s, box-shadow 0.1s;
    }

    .feat-group:hover { transform: translate(-2px, -2px); box-shadow: var(--shadow-lg); }

    .feat-header {
      background: var(--black);
      color: var(--white);
      padding: 0.65rem 1.1rem;
      font-size: 0.72rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }

    .feat-items { list-style: none; }

    .feat-item {
      padding: 0.85rem 1.1rem;
      border-bottom: 1px solid #CCCCCC;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.75rem;
      align-items: start;
    }

    .feat-item:last-child { border-bottom: none; }

    .feat-bullet {
      width: 6px;
      height: 6px;
      background: var(--black);
      margin-top: 6px;
      flex-shrink: 0;
    }

    .feat-name { font-size: 0.83rem; font-weight: 900; margin-bottom: 0.15rem; }

    .feat-desc {
      font-family: var(--font-mono);
      font-size: 0.74rem;
      color: #666;
      line-height: 1.5;
    }

    /* QUICKSTART */
    .qs-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
      align-items: start;
    }

    @media (max-width: 768px) { .qs-grid { grid-template-columns: 1fr; } }

    .steps { list-style: none; }

    .step {
      display: flex;
      gap: 1.1rem;
      margin-bottom: 1.5rem;
      align-items: start;
    }

    .step-num {
      background: var(--accent);
      border: var(--border);
      box-shadow: 3px 3px 0 #111;
      width: 2.2rem;
      height: 2.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 900;
      font-size: 0.88rem;
      font-family: var(--font-mono);
      flex-shrink: 0;
    }

    .step h4 {
      font-size: 0.82rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 0.3rem;
    }

    .step p {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: #555;
      line-height: 1.6;
    }

    /* CODE BLOCK */
    .code-block {
      background: #0D0D0D;
      color: var(--accent);
      font-family: var(--font-mono);
      font-size: 0.8rem;
      padding: 1.4rem 1.5rem;
      border: var(--border);
      box-shadow: var(--shadow);
      line-height: 1.9;
      overflow-x: auto;
      margin-bottom: 1.25rem;
    }

    .code-block .line { display: block; }
    .code-block .gap { display: block; height: 0.35rem; }
    .code-block .cmt { color: #444; }
    .code-block .cmd { color: #E5E5E5; }
    .code-block .arg { color: var(--accent); }

    /* NOTE */
    .note {
      border: var(--border);
      background: var(--bg-muted);
      box-shadow: var(--shadow);
      padding: 1.1rem 1.25rem;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      line-height: 1.65;
      color: #444;
    }

    .note strong {
      font-family: var(--font-sans);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      display: block;
      margin-bottom: 0.35rem;
      color: var(--black);
    }
</style>

<Base title="DevCell" description="DevCell — Run Claude Code, Codex, and OpenCode in an isolated container. One command from any project directory.">
  <div class="hero-wrap">
    <div class="hero">
      <div>
        <p class="hero-eyebrow">MIT License · Open Source</p>
        <h1>Container<br/>for AI<br/><span class="hl">agents</span></h1>
        <p class="hero-desc">
          One command launches Claude Code, Codex, or OpenCode in an isolated
          container. Your project directory is available at /workspace —
          nothing else is exposed.
        </p>
        <div class="hero-actions">
          <a href="https://github.com/DimmKirr/devcell" class="btn btn-primary">View on GitHub →</a>
          <a href="#quickstart" class="btn btn-secondary">Quickstart</a>
        </div>
      </div>

      <div class="terminal">
        <div class="terminal-bar">
          <span class="dot dot-r"></span>
          <span class="dot dot-y"></span>
          <span class="dot dot-g"></span>
        </div>
        <div><span class="t-path">~/myproject </span><span class="t-dim">on </span><span class="t-branch">main</span></div>
        <div><span class="t-cmd">$ cell claude</span></div>
        <div class="t-dim">starting container...</div>
        <div><span class="t-ok">✔ </span><span class="t-dim">image ready</span></div>
        <div><span class="t-ok">✔ </span><span class="t-dim">workspace mounted</span></div>
        <div class="t-dim">──────────────────────────</div>
        <div><span class="t-ok">Claude Code </span><span class="t-dim">ready in /workspace</span></div>
        <div><span class="t-cursor">▌</span></div>
      </div>
    </div>
  </div>

  <section id="what">
    <p class="section-label">Overview</p>
    <h2>What it does</h2>
    <div class="does-grid">
      <div class="does-card">
        <h3>Isolated execution</h3>
        <p>Runs AI agents inside Docker with full access to your project directory. The agent edits freely; your host system is untouched.</p>
      </div>
      <div class="does-card">
        <h3>Full toolchain</h3>
        <p>Debian base with Go, Node, Python, asdf, Docker CLI, Terraform, and more pre-installed. No extra setup per project.</p>
      </div>
      <div class="does-card">
        <h3>Reproducible via Nix</h3>
        <p>Nix home-manager pins every tool to an exact version. The environment is byte-identical across machines and rebuilds.</p>
      </div>
      <div class="does-card">
        <h3>GUI & desktop</h3>
        <p>VNC and X11 forwarding for running browsers and GUI tools inside the container — useful for Playwright and visual debugging.</p>
      </div>
      <div class="does-card">
        <h3>Project isolation</h3>
        <p>Each project gets its own container state, cell home, and Chrome profile. No state bleed between projects.</p>
      </div>
      <div class="does-card">
        <h3>One command, anywhere</h3>
        <p>Navigate to any repo and run <code>cell claude</code>. The working directory is mounted automatically — no project-level config needed.</p>
      </div>
    </div>
  </section>

  <div class="features-wrap" id="features">
    <section>
      <p class="section-label">Included packages</p>
      <h2>Feature set</h2>
      <div class="features-grid">
        {features.map((group) => (
          <div class="feat-group">
            <div class="feat-header">{group.category}</div>
            <ul class="feat-items">
              {group.items.map((item) => (
                <li class="feat-item">
                  <span class="feat-bullet"></span>
                  <div>
                    <div class="feat-name">{item.name}</div>
                    <div class="feat-desc">{item.desc}</div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  </div>

  <section id="quickstart">
    <p class="section-label">Getting started</p>
    <h2>Quickstart</h2>
    <div class="qs-grid">
      <ol class="steps">
        <li class="step">
          <span class="step-num">1</span>
          <div>
            <h4>Install</h4>
            <p>Download the <code>cell</code> binary for your platform from <a href="https://github.com/DimmKirr/devcell/releases">GitHub releases</a>. Requires <code>docker</code>.</p>
          </div>
        </li>
        <li class="step">
          <span class="step-num">2</span>
          <div>
            <h4>Initialize</h4>
            <p>Run <code>cell init</code> once. Scaffolds config and builds the Docker image (~5 min first time).</p>
          </div>
        </li>
        <li class="step">
          <span class="step-num">3</span>
          <div>
            <h4>Run from any project</h4>
            <p>Navigate to a repo and run <code>cell claude</code>, <code>cell codex</code>, or <code>cell opencode</code>. Working directory is mounted automatically.</p>
          </div>
        </li>
      </ol>

      <div>
        <div class="code-block">
          <span class="line"><span class="cmt"># download cell from GitHub releases</span></span>
          <span class="line"><span class="cmt"># github.com/DimmKirr/devcell/releases</span></span>
          <span class="gap"></span>
          <span class="line"><span class="cmt"># one-time setup — builds the Docker image</span></span>
          <span class="line"><span class="cmd">cell </span><span class="arg">init</span></span>
          <span class="gap"></span>
          <span class="line"><span class="cmt"># run from any project directory</span></span>
          <span class="line"><span class="cmd">cd </span>~/dev/my-project</span>
          <span class="line"><span class="cmd">cell </span><span class="arg">claude</span></span>
        </div>

        <div class="note">
          <strong>Note</strong>
          On first run, <code>cell claude</code> auto-scaffolds config and offers to build the image — so <code>cell init</code> is optional if you prefer an interactive first run.
        </div>
      </div>
    </div>
  </section>
</Base>
