---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const docs = await getCollection('cell');
  return docs.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allDocs = await getCollection('cell');

// Top-level subcommands only (one underscore, e.g. cell_claude not cell_codex_resume)
const topCommands = allDocs
  .filter((d) => d.id.startsWith('cell_') && d.id.split('_').length === 2)
  .sort((a, b) => a.id.localeCompare(b.id));

// Guide pages grouped by prefix
const guides = allDocs.filter((d) => d.id.startsWith('quickstart'));
const configDocs = allDocs
  .filter((d) => d.id === 'configuration' || d.id === 'stacks-and-modules')
  .sort((a, b) => a.id.localeCompare(b.id));
const howtos = allDocs
  .filter((d) => d.id.startsWith('howto-'))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
const mcpDocs = allDocs
  .filter((d) => d.id.startsWith('mcp-'))
  .sort((a, b) => {
    // mcp-overview always first
    if (a.id === 'mcp-overview') return -1;
    if (b.id === 'mcp-overview') return 1;
    return a.id.localeCompare(b.id);
  });

const currentId = entry.id;

// Build flat ordered list for prev/next navigation
const cliRoot = allDocs.filter((d) => d.id === 'cell');
const allOrdered = [...guides, ...configDocs, ...howtos, ...mcpDocs, ...cliRoot, ...topCommands];
const currentIndex = allOrdered.findIndex((d) => d.id === currentId);
const prevDoc = currentIndex > 0 ? allOrdered[currentIndex - 1] : null;
const nextDoc = currentIndex < allOrdered.length - 1 ? allOrdered[currentIndex + 1] : null;
---

<style is:global>
    .layout {
      max-width: 1200px;
      margin: 0 auto;
      padding: 3rem 2rem;
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 3rem;
      align-items: start;
    }

    @media (max-width: 768px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { display: none; }
      .sidebar.mobile-open { display: block; }
    }

    .mobile-docs-toggle {
      display: none;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 1px;
      background: var(--bg-muted);
      border: var(--border);
      padding: 0.6rem 1rem;
      cursor: pointer;
      width: 100%;
      text-align: left;
    }

    .mobile-docs-toggle:active { background: var(--accent); }

    @media (max-width: 768px) {
      .mobile-docs-toggle { display: block; }
    }

    .sidebar {
      position: sticky;
      top: 5rem;
      max-height: calc(100vh - 5rem);
      overflow-y: auto;
    }

    .sidebar-label {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #888;
      margin-bottom: 0.5rem;
    }

    .sidebar a {
      display: block;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: #555;
      text-decoration: none;
      padding: 0.25rem 0.5rem;
      border-left: 2px solid transparent;
      margin-bottom: 0.15rem;
      transition: border-color 0.1s, color 0.1s;
    }

    .sidebar a:hover { color: var(--black); border-left-color: var(--black); }
    .sidebar a.active { color: var(--black); border-left-color: var(--accent); font-weight: 900; }

    /* PROSE */
    .prose {
      min-width: 0;
      max-width: 720px;
    }

    .prose h1 {
      font-size: clamp(1.6rem, 4vw, 2.5rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: -1px;
      margin-bottom: 1.5rem;
      padding-bottom: 0.6rem;
      border-bottom: var(--border);
    }

    .prose h2 {
      font-size: 1rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin: 2rem 0 0.75rem;
      padding-bottom: 0.4rem;
      border-bottom: 1px solid #CCC;
    }

    .prose h3 {
      font-size: 0.85rem;
      font-weight: 900;
      text-transform: uppercase;
      margin: 1.5rem 0 0.5rem;
    }

    .prose p {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      color: #444;
      line-height: 1.75;
      margin-bottom: 1rem;
    }

    .prose pre {
      background: #0D0D0D;
      color: #C8FF00;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      padding: 1.1rem 1.25rem;
      border: var(--border);
      box-shadow: var(--shadow);
      overflow-x: auto;
      margin-bottom: 1.25rem;
      line-height: 1.8;
    }

    .prose pre code {
      background: none;
      border: none;
      padding: 0;
      color: inherit;
      font-size: inherit;
    }

    .prose a {
      color: var(--black);
      font-weight: 900;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .prose a:hover { background: var(--accent); text-decoration: none; }

    .prose ul {
      list-style: none;
      margin-bottom: 1rem;
      padding-left: 0;
    }

    .prose ul li {
      font-family: var(--font-mono);
      font-size: 0.83rem;
      color: #444;
      line-height: 1.7;
      padding-left: 1.1rem;
      position: relative;
    }

    .prose ul li::before {
      content: '▸';
      position: absolute;
      left: 0;
      color: #888;
      font-size: 0.7em;
      top: 0.25em;
    }

    .prose table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 1.25rem;
    }

    .prose th {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 900;
      text-align: left;
      padding: 0.4rem 0.75rem;
      border-bottom: var(--border);
    }

    .prose td {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: #444;
      padding: 0.4rem 0.75rem;
      border-bottom: 1px solid #E5E5E5;
      vertical-align: top;
    }

    .prose td code, .prose th code {
      font-size: 0.75rem;
    }

    .doc-nav {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid #CCC;
    }

    .doc-nav a {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: #555;
      text-decoration: none;
      padding: 0.5rem 0;
      transition: color 0.1s;
    }

    .doc-nav a:hover { color: var(--black); }
    .doc-nav .next { margin-left: auto; text-align: right; }
</style>

<Base title={`DevCell · ${entry.data.title}`} description={entry.data.description} activeNav="docs">
  <div class="layout">
    <aside class="sidebar">
      {guides.length > 0 && (
        <>
          <p class="sidebar-label">Getting started</p>
          {guides.map((doc) => (
            <a href={`/docs/${doc.id}`} class:list={[{ active: doc.id === currentId }]}>{doc.data.title}</a>
          ))}
        </>
      )}
      {configDocs.length > 0 && (
        <>
          <p class="sidebar-label" style="margin-top:1rem">Configuration</p>
          {configDocs.map((doc) => (
            <a href={`/docs/${doc.id}`} class:list={[{ active: doc.id === currentId }]}>{doc.data.title}</a>
          ))}
        </>
      )}
      {howtos.length > 0 && (
        <>
          <p class="sidebar-label" style="margin-top:1rem">Guides</p>
          {howtos.map((doc) => (
            <a href={`/docs/${doc.id}`} class:list={[{ active: doc.id === currentId }]}>{doc.data.title}</a>
          ))}
        </>
      )}
      {mcpDocs.length > 0 && (
        <>
          <p class="sidebar-label" style="margin-top:1rem">MCP servers</p>
          {mcpDocs.map((doc) => (
            <a href={`/docs/${doc.id}`} class:list={[{ active: doc.id === currentId }]}>{doc.data.title}</a>
          ))}
        </>
      )}
      <p class="sidebar-label" style="margin-top:1rem">CLI reference</p>
      <a href="/docs/cell" class:list={[{ active: currentId === 'cell' }]}>cell (root)</a>
      <p class="sidebar-label" style="margin-top:1rem">Commands</p>
      {topCommands.map((doc) => (
        <a
          href={`/docs/${doc.id}`}
          class:list={[{ active: doc.id === currentId }]}
        >
          {doc.id.replace('cell_', '')}
        </a>
      ))}
    </aside>

    <button class="mobile-docs-toggle" onclick="document.querySelector('.sidebar').classList.toggle('mobile-open'); this.textContent = document.querySelector('.sidebar').classList.contains('mobile-open') ? '▾ Hide docs menu' : '▸ Docs menu'">▸ Docs menu</button>

    <article class="prose">
      <Content />
      {(prevDoc || nextDoc) && (
        <nav class="doc-nav">
          {prevDoc ? <a href={`/docs/${prevDoc.id}`}>← {prevDoc.data.title}</a> : <span />}
          {nextDoc && <a class="next" href={`/docs/${nextDoc.id}`}>{nextDoc.data.title} →</a>}
        </nav>
      )}
    </article>
  </div>
</Base>
